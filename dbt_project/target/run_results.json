 "SELECT", "rows_affected": 40}, "message": "SELECT 40", "failures": null, "unique_id": "model.gold_price_dbt.fct_gold_prices", "compiled": true, "compiled_code": "with staging as (\n    select * from \"postgres\".\"gold_marts\".\"stg_gold_prices\"\n),\nhourly_metrics as (\n    select\n        brand,\n        date_trunc('hour', price_timestamp) as price_hour,\n        avg(buy_price) as avg_buy_price,\n        avg(sell_price) as avg_sell_price,\n        min(buy_price) as min_buy_price,\n        max(buy_price) as max_buy_price,\n        count(*) as data_points\n    from staging\n    group by 1, 2\n)\nselect * from hourly_metrics", "relation_name": "\"postgres\".\"gold_marts\".\"fct_gold_prices\"", "batch_results": null}], "elapsed_time": 5.455128908157349, "args": {"which": "run", "skip_nodes_if_on_run_start_fails": false, "upload_to_artifacts_ingest_api": false, "show_all_deprecations": false, "use_colors": true, "version_check": true, "defer": false, "empty": false, "require_yaml_configuration_for_mf_time_spines": false, "require_batched_execution_for_custom_microbatch_strategy": false, "require_ref_searches_node_package_before_root": false, "indirect_selection": "eager", "log_format": "default", "validate_macro_args": false, "use_fast_test_edges": false, "state_modified_compare_vars": false, "populate_cache": true, "log_level": "info", "send_anonymous_usage_stats": true, "static_parser": true, "exclude": [], "vars": {}, "use_colors_file": true, "macro_debugging": false, "favor_state": false, "require_generic_test_arguments_property": true, "log_file_max_bytes": 10485760, "partial_parse": true, "profiles_dir": ".", "write_json": true, "log_format_file": "debug", "introspect": true, "strict_mode": false, "require_all_warnings_handled_by_warn_error": false, "print": true, "partial_parse_file_diff": true, "cache_selected_only": false, "log_level_file": "debug", "printer_width": 80, "quiet": false, "require_nested_cumulative_type_params": false, "require_resource_names_