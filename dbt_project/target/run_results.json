_gold_prices", "compiled": true, "compiled_code": "with staging as (\n    select * from \"postgres\".\"gold_marts\".\"stg_gold_prices\"\n),\ndaily_metrics as (\n    select\n        brand,\n        price_date,\n        avg(buy_price) as avg_buy_price,\n        avg(sell_price) as avg_sell_price,\n        min(buy_price) as min_buy_price,\n        max(buy_price) as max_buy_price,\n        count(*) as data_points\n    from staging\n    group by 1, 2\n)\nselect * from daily_metrics", "relation_name": "\"postgres\".\"gold_marts\".\"fct_gold_prices\"", "batch_results": null}], "elapsed_time": 5.712078809738159, "args": {"require_all_warnings_handled_by_warn_error": false, "partial_parse_file_diff": true, "show_all_deprecations": false, "log_format": "default", "empty": false, "use_colors_file": true, "strict_mode": false, "write_json": true, "defer": false, "state_modified_compare_vars": false, "select": [], "quiet": false, "skip_nodes_if_on_run_start_fails": false, "require_explicit_package_overrides_for_builtin_materializations": true, "show_resource_report": false, "macro_debugging": false, "exclude": [], "require_generic_test_arguments_property": true, "static_parser": true, "use_fast_test_edges": false, "which": "run", "version_check": true, "invocation_command": "dbt run --profiles-dir .", "log_format_file": "debug", "profiles_dir": ".", "require_ref_searches_node_package_before_root": false, "warn_error_options": {"error": [], "warn": [], "silence": []}, "print": true, "printer_width": 80, "introspect": true, "indirect_selection": "eager", "log_file_max_bytes": 10485760, "vars": {}, "state_modified_compare_more_unrendered_values": false, "upload_to_artifacts_ingest_api": false, "require_nested_cumulative_type_params": false, "favor_state": false, "log_level": "info", "require_yaml_configuration_for_mf_time_spines": false, "validate_macro_args": false, "project_dir": "/home/tunguyenn99/my-project/gold-price-monitoring/dbt_project", "log_path": "/home/tunguyenn99/my-pr