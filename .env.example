# MongoDB Atlas Configuration
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# Supabase Postgres Configuration (Transaction Pooler - Port 6543)
SUPABASE_DB_URL=postgresql://postgres.<project_id>:<password>@<host>:6543/postgres
SUPABASE_DB_PASSWORD=your_supabase_password
SUPABASE_DB_HOST=aws-0-ap-northeast-2.pooler.supabase.com
SUPABASE_DB_USER=postgres.<project_id>
SUPABASE_DB_PORT=6543

# Optional: Direct Connection URL (for local dbt testing if needed)
# DATABASE_URL=postgresql://postgres:<password>@db.<project_id>.supabase.co:5432/postgres
